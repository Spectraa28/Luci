# ── Provider (pick one, paste its key) ───────────────────────────────────────
LUCI_PROVIDER=anthropic          # anthropic | openai | gemini | deepseek | openrouter

ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...
# DEEPSEEK_API_KEY=...
# OPENROUTER_API_KEY=...

# ── Model overrides (optional — defaults are set per provider) ────────────────
# LUCI_MODEL=claude-sonnet-4-6
# LUCI_SMALL_MODEL=claude-haiku-4-5-20251001

# ── Home directory (where Luci keeps state.db, traces/, MEMORY.md) ───────────
# LUCI_HOME=.luci

# ── Loop guardrails ───────────────────────────────────────────────────────────
# LUCI_MAX_ITERATIONS=10
# LUCI_MAX_TOKENS=2048

# ── Memory ────────────────────────────────────────────────────────────────────
# LUCI_CONSOLIDATE_EVERY=6
# LUCI_RETRIEVAL_TOP_K=4
# LUCI_SEMANTIC_STORE=sqlite       # sqlite | supabase

# ── Web search (optional, improves search_web results) ───────────────────────
# TAVILY_API_KEY=tvly-...

# ── Optional gateways ─────────────────────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=...

# ── Apple ecosystem (macOS only, opt-in) ──────────────────────────────────────
# LUCI_APPLE_CALENDAR=1
# LUCI_APPLE_TOOLS=1

# ── Experimental tools (sub-agents, browser, terminal) ───────────────────────
# LUCI_EXPERIMENTAL=1

# ── Tracing (JSONL always; OTel exports if set) ───────────────────────────────
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
